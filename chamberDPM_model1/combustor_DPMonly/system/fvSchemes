/*--------------------------------*- C++ -*----------------------------------*\
  OpenFOAM v13  |  fvSchemes
  Pintle injector DPM simulation
\*---------------------------------------------------------------------------*/

FoamFile
{
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;  // First-order implicit for stability
}

gradSchemes
{
    default         Gauss linear;
    grad(p)         Gauss linear;
    grad(p_rgh)     Gauss linear;
    grad(U)         cellLimited Gauss linear 1;
    grad(k)         cellLimited Gauss linear 1;
    grad(epsilon)   cellLimited Gauss linear 1;
}

divSchemes
{
    default             none;

    // Momentum convection
    div(phi,U)          Gauss linearUpwind grad(U);

    // Energy convection
    div(phi,h)          Gauss linearUpwind grad(h);
    div(phi,K)          Gauss linearUpwind grad(h);
    div(phi,Ekp)        Gauss linearUpwind grad(h);

    // Turbulence
    div(phi,k)          Gauss linearUpwind grad(k);
    div(phi,epsilon)    Gauss linearUpwind grad(epsilon);

    // Species
    div(phi,Yi_h)       Gauss linearUpwind grad(Yi);

    // Pressure work
    div(phid,p)         Gauss limitedLinear 1;

    // Viscous stress
    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;
    div((muEff*dev2(T(grad(U)))))       Gauss linear;

    // Kinematic cloud (particle source terms)
    div(U)              Gauss linear;
}

laplacianSchemes
{
    default             Gauss linear corrected;
    laplacian(muEff,U)  Gauss linear corrected;
    laplacian(alphaEff,h) Gauss linear corrected;
}

interpolationSchemes
{
    default             linear;
}

snGradSchemes
{
    default             corrected;
}

fluxRequired
{
    default         no;
    p_rgh           ;
    p               ;
}

wallDist
{
    method          meshWave;
}

