FoamFile
{
    format      binary;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 5;

boundaryField
{
    Wall
    {
        type            kqRWallFunction;
        value           uniform 5;
    }
    fluid-for-engine-interior-for-3d-cad:1
    {
        type            kqRWallFunction;
        value           uniform 5;
    }
    fuelInlet
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.05;
        value           uniform 5;
    }
    oxidiserInlet
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.05;
        value           uniform 5;
    }
    wedge_pos
    {
        type            symmetry;
    }
    wedge_neg
    {
        type            symmetry;
    }
    Outlet
    {
        type            inletOutlet;
        inletValue      uniform 5;
        value           uniform 5;
    }
}


